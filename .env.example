# =====================================================
# CUBICZAN Agent Swarm Intelligence Platform
# Environment Configuration
# =====================================================

# ============= PRIMARY LLM (Orchestrator) =============
# Any OpenAI SDK-compatible API. For self-hosted, use Ollama or vLLM.
# Cloud options: OpenAI, Anthropic (via proxy), DeepSeek, Qwen (Alibaba)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b

# ============= AGENT MODELS (Heterogeneous Pool) =============
# Use different models for anti-sycophancy. At least 2-3 distinct models.
AGENT_MODEL_1_API_KEY=your_key
AGENT_MODEL_1_BASE_URL=http://localhost:11434/v1
AGENT_MODEL_1_NAME=qwen2.5:32b

AGENT_MODEL_2_API_KEY=your_key
AGENT_MODEL_2_BASE_URL=http://localhost:11434/v1
AGENT_MODEL_2_NAME=deepseek-r1:32b

AGENT_MODEL_3_API_KEY=your_key
AGENT_MODEL_3_BASE_URL=http://localhost:11434/v1
AGENT_MODEL_3_NAME=llama3.3:latest

# ============= NANO ROUTER MODEL =============
# Cheap/fast model for MoE routing ($0.02-0.20/M tokens)
ROUTER_MODEL_API_KEY=your_key
ROUTER_MODEL_BASE_URL=http://localhost:11434/v1
ROUTER_MODEL_NAME=qwen2.5:7b

# ============= ZEP MEMORY =============
# Zep Cloud: https://app.getzep.com/ (free tier available)
# Or self-hosted Zep: https://github.com/getzep/zep
ZEP_API_KEY=your_zep_api_key_here

# ============= NEO4J (Knowledge Graph) =============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cubiczan_secure_password

# ============= QDRANT (Vector Store) =============
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ============= REDIS (Message Queue) =============
REDIS_URL=redis://localhost:6379/0

# ============= MONITORING =============
GRAFANA_ADMIN_PASSWORD=cubiczan_admin

# ============= DOMAIN SELECTION =============
# Comma-separated list of active domains
# Options: financial, cybersecurity, business-intel, predictive-sim,
#          content-marketing, healthcare, political, real-estate, talent-hr
ACTIVE_DOMAINS=financial,cybersecurity,business-intel

# ============= SWARM CONFIGURATION =============
# Agents per cluster (3-4 optimal per Google Research)
AGENTS_PER_CLUSTER=4
# Max simulation rounds
MAX_SIMULATION_ROUNDS=20
# Consensus threshold (0.0-1.0)
CONSENSUS_THRESHOLD=0.75
# Anti-sycophancy: minimum model diversity per cluster
MIN_MODEL_DIVERSITY=2

# ============= BOOST LLM (Optional) =============
# Faster model for acceleration tasks
# LLM_BOOST_API_KEY=your_key
# LLM_BOOST_BASE_URL=your_url
# LLM_BOOST_MODEL_NAME=your_model
